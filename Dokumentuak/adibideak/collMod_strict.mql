// ============================================================
// collMod con validación ESTRICTA (validationLevel: "strict")
// Se aplica a todas las inserciones Y actualizaciones.
// Los documentos que incumplan el esquema son RECHAZADOS.
// ============================================================

db.runCommand({
  collMod: "productos",
  validator: {
    $jsonSchema: {
      bsonType: "object",
      title: "Esquema de producto (validación estricta)",
      required: ["nombre", "categoria", "precio", "stock", "activo"],
      additionalProperties: false,
      properties: {
        _id: {
          bsonType: "objectId"
        },
        nombre: {
          bsonType: "string",
          minLength: 2,
          maxLength: 100,
          description: "Nombre del producto. Obligatorio, entre 2 y 100 caracteres."
        },
        categoria: {
          bsonType: "string",
          enum: ["electronica", "perifericos", "accesorios", "software"],
          description: "Categoría. Obligatoria, debe ser uno de los valores permitidos."
        },
        precio: {
          bsonType: "double",
          minimum: 0.01,
          description: "Precio en euros. Obligatorio, mayor que 0."
        },
        stock: {
          bsonType: "int",
          minimum: 0,
          description: "Unidades disponibles. Obligatorio, entero no negativo."
        },
        activo: {
          bsonType: "bool",
          description: "Indica si el producto está disponible. Obligatorio."
        },
        etiquetas: {
          bsonType: "array",
          items: {
            bsonType: "string"
          },
          description: "Lista de etiquetas. Opcional, cada elemento debe ser string."
        },
        especificaciones: {
          bsonType: "object",
          required: ["marca", "modelo", "garantia_meses"],
          additionalProperties: false,
          properties: {
            marca: {
              bsonType: "string"
            },
            modelo: {
              bsonType: "string"
            },
            garantia_meses: {
              bsonType: "int",
              minimum: 0
            }
          },
          description: "Especificaciones técnicas. Opcional pero si aparece, campos obligatorios."
        }
      }
    }
  },
  validationLevel: "strict",   // aplica a inserciones y actualizaciones
  validationAction: "error"    // rechaza documentos inválidos
});
