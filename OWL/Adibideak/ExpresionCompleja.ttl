@prefix : <http://vocab.ehu.eus/abd-01/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://vocab.ehu.eus/abd-01/> .

<http://vocab.ehu.eus/abd-01> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://vocab.ehu.eus/abd-01/empadronado
:empadronado rdf:type owl:ObjectProperty .


###  http://vocab.ehu.eus/abd-01/parte_de
:parte_de rdf:type owl:ObjectProperty .


###  http://vocab.ehu.eus/abd-01/presentaRenta
:presentaRenta rdf:type owl:ObjectProperty .


###  http://vocab.ehu.eus/abd-01/residencia
:residencia rdf:type owl:ObjectProperty .


#################################################################
#    Classes
#################################################################

###  http://vocab.ehu.eus/abd-01/CiudadanoVasco
:CiudadanoVasco rdf:type owl:Class ;
                owl:equivalentClass [ rdf:type owl:Class ;
                                      owl:unionOf ( [ rdf:type owl:Restriction ;
                                                      owl:onProperty :residencia ;
                                                      owl:someValuesFrom [ rdf:type owl:Class ;
                                                                           owl:unionOf ( :Euskadi
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty :parte_de ;
                                                                                           owl:someValuesFrom :Euskadi
                                                                                         ]
                                                                                       )
                                                                         ]
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :empadronado ;
                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :parte_de ;
                                                                    owl:someValuesFrom :Euskadi
                                                                  ]
                                                    ]
                                                  )
                                    ] ;
                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                  owl:onProperty :presentaRenta ;
                                  owl:someValuesFrom :RentaEuskadi
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :presentaRenta ;
                                  owl:allValuesFrom :RentaEuskadi
                                ] .


###  http://vocab.ehu.eus/abd-01/Euskadi
:Euskadi rdf:type owl:Class .


###  http://vocab.ehu.eus/abd-01/RentaAlava
:RentaAlava rdf:type owl:Class ;
            rdfs:subClassOf :RentaEuskadi .


###  http://vocab.ehu.eus/abd-01/RentaBizkaia
:RentaBizkaia rdf:type owl:Class ;
              rdfs:subClassOf :RentaEuskadi .


###  http://vocab.ehu.eus/abd-01/RentaEuskadi
:RentaEuskadi rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:unionOf ( :RentaAlava
                                                  :RentaBizkaia
                                                  :RentaGipuzkoa
                                                )
                                  ] .


###  http://vocab.ehu.eus/abd-01/RentaGipuzkoa
:RentaGipuzkoa rdf:type owl:Class ;
               rdfs:subClassOf :RentaEuskadi .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :RentaAlava
                :RentaBizkaia
                :RentaGipuzkoa
              )
] .


