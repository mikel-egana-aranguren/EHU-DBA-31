<rdf:Description rdf:about="P01308#SIP804064636D32F723">
<rdf:type rdf:resource="http://purl.uniprot.org/core/Function_Annotation"/>
<rdfs:comment>Insulin decreases blood glucose concentration. It increases cell permeability to monosaccharides, amino acids and fatty acids. It accelerates glycolysis, the pentose phosphate cycle, and glycogen synthesis in liver.</rdfs:comment>
</rdf:Description>
<rdf:Description rdf:about="P01308#SIPDD113FDE2806831E">
